PORT=3001

MONGO_URI=your_mongodb_connection_string

# Optional
# MONGO_DB_NAME=graduation_invite
REQUIRE_MONGO=true
# Set false only for temporary offline development
# REQUIRE_MONGO=false

# Keep false in production so image uploads fail fast if Cloudinary is wrong.
ALLOW_LOCAL_IMAGE_FALLBACK=false
# Set true only for temporary local/offline development
# ALLOW_LOCAL_IMAGE_FALLBACK=true

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://final-du-beta.vercel.app