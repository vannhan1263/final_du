{
  "name": "graduation-invite",
  "version": "2.0.0",
  "private": true,
  "description": "Graduation invitation – React + Express",
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "build": "npm --prefix client run build",
    "postinstall": "npm --prefix server install",
    "start": "npm --prefix server run start",
    "install:all": "npm install && npm --prefix client install && npm --prefix server install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "lucide-react": "^1.8.0"
  }
}
